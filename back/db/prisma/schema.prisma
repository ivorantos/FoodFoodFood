generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum RecipeType {
  PR   // Primero
  SG   // Segundo
  AC   // Acompañamiento
  PU   // plato unico
  CN   // cena
  DS   // dulce postre
  SN   // snack/salsa/otro
}

enum Season {
  invierno
  primavera
  verano
  otoño
}

enum Context {
  comida
  cena
}

// =======================
// Modelo de recetas
// =======================
model Recipe {
  id              String   @id @default(uuid())
  name            String   @unique
  type            RecipeType?
  context         RecipeContext[]
  ingredients     String
  recipe          String
  planEntries     SlotEntry[]
  notes           String?
  season          Season?
  createdAt       DateTime @default(now())
  robot           Boolean
  updatedAt       DateTime @updatedAt
  proteinas       Float?
  grasas          Float?
  carbohidratos   Float?
  calorias        Int?
  frequency       Int?            // 1-5 or null
  prepTime        Int?            // minutos de preparación activa
  isComponent     Boolean         @default(false)  // excluir del planning (masas, salsas, bechamel...)
  requiresPrevDay Boolean         @default(false)  // necesita remojo/fermentación/marinado previo
  mainIngredient  String?         // JSON array: '["PASTA","CARNE"]'
  relatedFrom     RecipeRelation[] @relation("from")
  relatedTo       RecipeRelation[] @relation("to")

  @@index([type, name, season, id])
}

model RecipeRelation {
  recipeId  String
  relatedId String
  recipe    Recipe @relation("from", fields: [recipeId], references: [id], onDelete: Cascade)
  related   Recipe @relation("to", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([recipeId, relatedId])
}

// =======================
// Modelo de contexto en recetas
// =======================
model RecipeContext {
  id       String  @id @default(uuid())
  context  Context
  recipe   Recipe  @relation(fields: [recipeId], references: [id])
  recipeId String
}

// =======================
// Modelo de ingredientes
// =======================
model Ingredients {
  id        String   @id @default(uuid())
  name      String
  updatedAt DateTime @updatedAt

  @@index([name, id])
}

model WeekPlan {
  id        String     @id @default(uuid())
  weekStart String     @unique  // "YYYY-MM-DD" del lunes
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  slots     MealSlot[]
}

model MealSlot {
  id         String       @id @default(uuid())
  weekPlanId String
  weekPlan   WeekPlan     @relation(fields: [weekPlanId], references: [id], onDelete: Cascade)
  date       String       // "YYYY-MM-DD"
  mealType   PlanMealType
  entries    SlotEntry[]

  @@unique([weekPlanId, date, mealType])
}

model SlotEntry {
  id         String    @id @default(uuid())
  slotId     String
  slot       MealSlot  @relation(fields: [slotId], references: [id], onDelete: Cascade)
  recipeId   String?
  recipe     Recipe?   @relation(fields: [recipeId], references: [id], onDelete: SetNull)
  recipeName String
  isCustom   Boolean   @default(false)
  order      Int       @default(0)
}

enum PlanMealType {
  lunch
  dinner
}